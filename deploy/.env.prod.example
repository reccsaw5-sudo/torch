# Copy to deploy/.env.prod and fill in real values. Never commit .env.prod.
#   cp deploy/.env.prod.example deploy/.env.prod
# 或直接用 deploy/gen-env.sh 生成随机的强 Token + 数据库密码。

# Public domain. DNS A record must point at this server; Caddy issues the HTTPS
# cert for it. Used for TORCH_PUBLIC_BASE and all WeChat/payment callbacks.
TORCH_DOMAIN=claw.torchai.ai

# PostgreSQL credentials (used by both the postgres container and torch-server).
#   生成强密码: openssl rand -hex 24
POSTGRES_USER=torch
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_24
POSTGRES_DB=torch

# Admin console token (torch-admin-ui login / X-Admin-Token). MUST be strong.
#   生成: openssl rand -hex 32
TORCH_ADMIN_TOKEN=CHANGE_ME_strong_admin_token

# Credits granted to each newly registered user.
TORCH_SIGNUP_CREDITS=1000

# --- 拉镜像部署(docker-compose.registry.yml)用;build 部署可忽略 ---
# 你的镜像仓库(阿里云 ACR)。build-and-push.sh 推、registry compose 拉。
TORCH_IMAGE_REPO=registry.cn-shanghai.aliyuncs.com/gongyong1/hermes
TORCH_SERVER_TAG=torch-server
TORCH_EDGE_TAG=edge
